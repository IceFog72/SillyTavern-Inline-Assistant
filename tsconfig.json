{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "allowJs": false,
    "checkJs": false,
    "rootDir": "src",
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/**/*.ts"]
}
