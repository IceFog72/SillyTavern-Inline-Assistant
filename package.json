{
  "name": "sillytavern-inline-assistant",
  "version": "0.1.0",
  "description": "SillyTavern extension for inline completion and translation preview.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "esbuild src/index.ts --bundle --format=iife --target=es2022 --external:/scripts/extensions/shared.js --external:/scripts/extensions/translate/index.js --outfile=index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IceFog72/SillyTavern-Inline-Assistant.git"
  },
  "keywords": [
    "sillytavern",
    "extension",
    "autocomplete",
    "translation"
  ],
  "author": "IceFog72",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/IceFog72/SillyTavern-Inline-Assistant/issues"
  },
  "homepage": "https://github.com/IceFog72/SillyTavern-Inline-Assistant#readme",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
